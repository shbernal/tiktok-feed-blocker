{
  "manifest_version": 3,
  "name": "TikTok Feed Blocker",
  "version": "1.0.0",
  "content_scripts": [
    {
      "matches": ["*://*.tiktok.com/explore*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],

  "permissions": [
    "activeTab", "storage", "tabs"
  ],

  "background": {
    "service_worker": "background.js"
  },
  
  "action": {
    "default_popup": "index.html"
  }
}